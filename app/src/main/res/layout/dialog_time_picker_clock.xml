<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/bg_time_picker_floating"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/layout_time_header"
        android:layout_width="match_parent"
        android:layout_height="136dp"
        android:background="#F4F7FB"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="18dp">

        <TextView
            android:id="@+id/tv_picker_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/time_picker_title"
            android:textColor="#6C7A89"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/layout_time_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_selected_hour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:text="@string/time_zero"
                android:textColor="#192330"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/time_separator"
                android:textColor="#192330"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_selected_minute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:text="@string/time_zero"
                android:textColor="#8D99A8"
                android:textSize="34sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_time_input_inline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <EditText
                android:id="@+id/et_input_hour"
                android:layout_width="72dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_time_picker_input"
                android:gravity="center"
                android:hint="@string/time_picker_hour_hint"
                android:imeOptions="actionNext"
                android:importantForAutofill="no"
                android:inputType="number"
                android:maxLength="2"
                android:text="@string/time_zero"
                android:textColor="#192330"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:text="@string/time_separator"
                android:textColor="#192330"
                android:textSize="28sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_input_minute"
                android:layout_width="72dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_time_picker_input"
                android:gravity="center"
                android:hint="@string/time_picker_minute_hint"
                android:imeOptions="actionDone"
                android:importantForAutofill="no"
                android:inputType="number"
                android:maxLength="2"
                android:text="@string/time_zero"
                android:textColor="#192330"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_clock_container"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="14dp">

        <com.lewis.timetable.RadialClockFaceView
            android:id="@+id/radial_clock_face"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_input_toggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/time_picker_toggle_mode"
            android:padding="8dp"
            android:src="@drawable/ic_time_keyboard"
            app:tint="#506072" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btn_dismiss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="8dp"
            android:text="@string/common_cancel"
            android:textColor="#677587"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_time_picker_input"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/common_confirm"
            android:textColor="#192330"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
